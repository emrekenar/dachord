{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MusicTheory": {
    "Notes": {
      "C": 0, "C#": 1, "Db": 1, "D": 2, "D#": 3, "Eb": 3, "E": 4,
      "F": 5, "F#": 6, "Gb": 6, "G": 7, "G#": 8, "Ab": 8, "A": 9,
      "A#": 10, "Bb": 10, "B": 11
    },
    "ChordQualities": [
      { "Id": "", "Name": "Major", "Intervals": [0, 4, 7] },
      { "Id": "m", "Name": "Minor", "Intervals": [0, 3, 7] },
      { "Id": "maj7", "Name": "Major 7th", "Intervals": [0, 4, 7, 11] },
      { "Id": "m7", "Name": "Minor 7th", "Intervals": [0, 3, 7, 10] },
      { "Id": "dim", "Name": "Diminished", "Intervals": [0, 3, 6] }
    ]
  },
  "Jwt": {
    "Issuer": "DachordApi",
    "Audience": "DachordApp",
    "ExpireMinutes": 120
  },
  "Spotify": {
    "BaseUrl": "https://api.spotify.com"
  },
  "AWS": {
    "ServiceURL": "http://localhost:4566",
    "Region": "us-east-1"
  },
  "DynamoDb": {
    "TableName": "Tracks"
  },
  "AllowedHosts": "*"
}
